{
  "name": "aura-weather",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:safe": "vite --host 127.0.0.1 --port 5173 --strictPort false",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node --test",
    "test:render": "node --test 'src/**/*.render.test.mjs'",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:visual": "playwright test e2e/visual-regression.spec.js",
    "test:visual:update": "playwright test e2e/visual-regression.spec.js --update-snapshots",
    "test:lighthouse": "npm run build && node scripts/run-lighthouse-budgets.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^12.6.1",
    "prettier": "^3.8.3",
    "vite": "^6.4.0"
  }
}
