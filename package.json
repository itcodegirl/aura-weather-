{
  "name": "aura-weather",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A resilient, accessible React weather dashboard — live forecast, hourly outlook, air quality, severe-weather alerts, and source-aware data-trust cues, with offline restore and a PWA shell.",
  "keywords": [
    "weather",
    "weather-dashboard",
    "react",
    "vite",
    "pwa",
    "open-meteo",
    "accessibility",
    "portfolio"
  ],
  "homepage": "https://aura-weather-platform.netlify.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/itcodegirl/aura-weather.git"
  },
  "bugs": {
    "url": "https://github.com/itcodegirl/aura-weather/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:safe": "vite --host 127.0.0.1 --port 5173 --strictPort false",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node --test",
    "test:render": "node scripts/run-render-tests.mjs",
    "test:components": "npm run test:render",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:visual": "playwright test e2e/visual-regression.spec.js",
    "test:visual:update": "playwright test e2e/visual-regression.spec.js --update-snapshots",
    "test:lighthouse": "npm run build && node scripts/run-lighthouse-budgets.mjs",
    "screenshots": "playwright test e2e/readme-screenshots.spec.js e2e/trust-contract-screenshot.spec.js",
    "record:trust-contract-demo": "node scripts/record-trust-contract-demo.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^12.6.1",
    "prettier": "^3.8.3",
    "vite": "^6.4.0"
  }
}
